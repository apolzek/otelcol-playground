# Fast dev image for Tilt. The loadgen binary is compiled on the HOST by the
# `backend-compile` local_resource and copied in here; Tilt's live_update then
# syncs new builds straight into the running container (no image rebuild).
#
# telemetrygen lives in a cached build stage so it isn't reinstalled on edits.
FROM golang:1.26 AS tools
ARG TELEMETRYGEN_VERSION=v0.154.0
ENV CGO_ENABLED=0 GOOS=linux
RUN go install github.com/open-telemetry/opentelemetry-collector-contrib/cmd/telemetrygen@${TELEMETRYGEN_VERSION}

FROM alpine:3.20
RUN adduser -D -u 10001 app
COPY --from=tools /go/bin/telemetrygen /usr/local/bin/telemetrygen
# Pre-built on the host (see Tiltfile: backend-compile)
COPY build/loadgen /usr/local/bin/loadgen
USER app

ENV TELEMETRYGEN_BIN=/usr/local/bin/telemetrygen \
    COLLECTOR_METRICS_URL=http://otelcol:8888/metrics \
    LISTEN_ADDR=:8080
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/loadgen"]
